ACTIVEPIECES_VERSION=0.83.0
ACTIVEPIECES_PORT=8090

# Optional absolute host paths. When unset, docker-compose uses:
#   JAZ_INGEST_ROOT=${HOME}/.jaz/ingest
#   JAZ_MEMORY_ROOT=${HOME}/.jaz/memory
# Packaged installers should write explicit per-user paths when they use a
# runtime root other than the user's home directory.
# JAZ_INGEST_ROOT=/absolute/path/to/.jaz/ingest
# JAZ_MEMORY_ROOT=/absolute/path/to/.jaz/memory
#
# Jaz Activepieces piece. Source/releases live in a separate repository, not
# the Jaz repo. Packaged installers should set the archive URL for their target
# piece version, or bundle the archive under activepieces/piece-archives/.
JAZ_LAKE_WRITER_PIECE_NAME=@activepieces/piece-lake-writer
JAZ_LAKE_WRITER_PIECE_VERSION=0.1.2
JAZ_LAKE_WRITER_ARCHIVE_URL=https://github.com/gluonfield/jaz-activepieces-lake-writer/releases/download/v0.1.2/activepieces-piece-lake-writer-0.1.2.tgz

AP_ENGINE_EXECUTABLE_PATH=dist/packages/engine/main.js
AP_API_KEY=replace-with-random-hex
AP_ENCRYPTION_KEY=replace-with-32-hex-characters
AP_JWT_SECRET=replace-with-random-hex

AP_ENVIRONMENT=prod
AP_PORT=80
AP_FRONTEND_URL=http://localhost:8090
AP_INTERNAL_URL=http://127.0.0.1:80
AP_WEBHOOK_TIMEOUT_SECONDS=30
AP_TRIGGER_DEFAULT_POLL_INTERVAL=5

AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_HOST=postgres
AP_POSTGRES_PORT=5432
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=replace-with-random-password

AP_EXECUTION_MODE=UNSANDBOXED
AP_REDIS_HOST=redis
AP_REDIS_PORT=6379
AP_FLOW_TIMEOUT_SECONDS=600
AP_TELEMETRY_ENABLED=false
AP_TEMPLATES_SOURCE_URL=https://cloud.activepieces.com/api/v1/flow-templates

# admin login used by piece-installer
AP_ADMIN_EMAIL=
AP_ADMIN_PASSWORD=
